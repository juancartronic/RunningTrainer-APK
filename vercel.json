{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/strava-token", "dest": "/api/strava-token.js" },
    { "src": "/callback", "dest": "/callback.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
